# ============================================================
# NEXO MÍDIA — Variáveis de Ambiente
# Copie este arquivo para ".env" e ajuste os valores.
# NUNCA versione o arquivo ".env" real (contém segredos).
# ============================================================

# ---- Ambiente ----
# development | testing | production
FLASK_ENV=development
FLASK_APP=wsgi.py
FLASK_DEBUG=1

# ---- Segurança ----
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=troque-esta-chave-em-producao-0000000000000000000000000000
SECURITY_PASSWORD_SALT=troque-este-salt-0000000000000000000000000000000

# ---- Banco de dados ----
# Desenvolvimento/Testes (SQLite) — deixe em branco para usar SQLite automaticamente
# Produção (PostgreSQL), exemplo:
# DATABASE_URL=postgresql+psycopg2://nexo_user:senha_forte@localhost:5432/nexo_midia
DATABASE_URL=sqlite:///dev.sqlite3
TEST_DATABASE_URL=sqlite:///:memory:

SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE=1800
SQLALCHEMY_POOL_PRE_PING=1

# ---- Sessão / Cookies ----
SESSION_COOKIE_SECURE=0
REMEMBER_COOKIE_SECURE=0
PERMANENT_SESSION_LIFETIME_MINUTES=60

# ---- Rate Limiting ----
# memory:// para dev; redis://localhost:6379/0 para produção (múltiplos workers)
RATELIMIT_STORAGE_URI=memory://
RATELIMIT_DEFAULT=200 per day;50 per hour

# ---- Uploads ----
UPLOAD_FOLDER=app/static/uploads
MAX_CONTENT_LENGTH_MB=80
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,webp,gif
ALLOWED_VIDEO_EXTENSIONS=mp4,webm

# ---- WhatsApp / Empresa ----
COMPANY_NAME=Nexo Mídia
COMPANY_WHATSAPP=5567999990000
COMPANY_EMAIL=contato@nexomidia.com.br
COMPANY_PHONE=(67) 3241-5050
COMPANY_ADDRESS=Av. Afonso Pena, 1200 — Campo Grande, MS

# ---- Administrador inicial (usado por scripts/seed.py) ----
ADMIN_NAME=Administrador Principal
ADMIN_EMAIL=admin@nexomidia.com.br
ADMIN_PASSWORD=troque-esta-senha-forte-123!

# ---- Logs ----
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_TO_STDOUT=1

# ---- CORS (para futuras integrações via API) ----
CORS_ORIGINS=http://localhost:3000

# ---- Proxy reverso (produção atrás de Nginx) ----
BEHIND_PROXY=0

# ---- HTTPS / Talisman ----
FORCE_HTTPS=0
