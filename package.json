{
  "name": "midia-indoor-frontend",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "description": "Build estático de assets front-end (Tailwind CSS + fontes self-hosted) do painel Nexo Mídia.",
  "scripts": {
    "build:css": "tailwindcss -i ./assets/input.css -o ./app/static/css/tailwind.min.css --minify",
    "watch:css": "tailwindcss -i ./assets/input.css -o ./app/static/css/tailwind.min.css --watch",
    "build": "npm run build:css"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.13"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "@fontsource/space-grotesk": "^5.1.0"
  }
}
